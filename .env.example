# ── LLM / Embeddings ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Use "memory://" to skip MongoDB and use an in-process store (dev/test)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=adaptive_rag

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave blank for local, set for Qdrant Cloud
QDRANT_COLLECTION=documents

# ── FAISS fallback ────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./faiss_index

# ── Feature flags ─────────────────────────────────────────────────────────────
# Options: qdrant | faiss
FEATURE_VECTOR_BACKEND=qdrant

# ── LangSmith observability ───────────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=adaptive-rag-ops-lab
LANGSMITH_TRACING=true

# ── Model config ─────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=0.7

# ── n8n alerting ─────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
EVAL_THRESHOLD=0.5
